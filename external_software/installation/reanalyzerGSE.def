# Function to install and properly handle dependencies
install_pkgs_batched <- function(pkgs) {
  cat("Analyzing dependencies...\n")
  
  # Get dependency info
  raw_deps <- pak::pkg_deps(pkgs, upgrade = FALSE)
  
  # Force to plain data.frame, preserve list-columns
  deps_info <- as.data.frame(raw_deps, stringsAsFactors = FALSE)
  n_rows <- as.integer(nrow(deps_info))
  cat(sprintf("deps_info has %d rows\n", n_rows))
  
  # Extract scalar columns directly from raw tibble
  deps_info[["ref"]]     <- as.character(raw_deps[["ref"]])
  deps_info[["package"]] <- as.character(raw_deps[["package"]])
  deps_info[["version"]] <- as.character(raw_deps[["version"]])
  
  # Sanitize: if package looks like "pkg@version", fix it
  bad_pkg <- grepl("@", deps_info[["package"]])
  if (any(bad_pkg)) {
    deps_info[["package"]][bad_pkg] <- sub("@.*$", "", deps_info[["ref"]][bad_pkg])
  }
  
  # Sanitize: if version looks like "pkg@version" or equals package name, fix it
  bad_ver <- deps_info[["version"]] == deps_info[["package"]] |
             deps_info[["version"]] == deps_info[["ref"]]     |
             grepl("@", deps_info[["version"]])
  if (any(bad_ver)) {
    deps_info[["version"]][bad_ver] <- ifelse(
      grepl("@", deps_info[["ref"]][bad_ver]),
      sub("^[^@]+@", "", deps_info[["ref"]][bad_ver]),
      NA_character_
    )
  }
  
  # Preserve the deps list-column from raw
  deps_info[["deps"]] <- raw_deps[["deps"]]
  
  cat("Sample of deps_info:\n")
  print(data.frame(
    ref     = head(deps_info[["ref"]], 8),
    package = head(deps_info[["package"]], 8),
    version = head(deps_info[["version"]], 8),
    stringsAsFactors = FALSE
  ))
  
  get_dep_df <- function(idx) {
    if (idx < 1 || idx > length(deps_info[["deps"]])) return(NULL)
    df <- deps_info[["deps"]][[idx]]
    if (is.data.frame(df) && nrow(df) > 0) return(df)
    return(NULL)
  }
  
  is_dep_type <- function(type_vec) {
    tolower(as.character(type_vec)) %in% c("imports", "depends", "linkingto")
  }
  
  make_pkg_string <- function(p) {
    row_idx <- match(p, deps_info[["package"]])
    if (is.na(row_idx)) return(as.character(p))
    ref <- deps_info[["ref"]][row_idx]
    ver <- deps_info[["version"]][row_idx]
    if (!is.na(ref) && grepl("@", ref) && !grepl("@NA$", ref)) {
      return(as.character(ref))
    }
    if (!is.na(ver) && ver != "" && ver != p && ver != "NA") {
      return(paste0(p, "@", ver))
    }
    return(as.character(p))
  }
  
  # Identify extra deps
  all_dep_pkgs <- unique(unlist(lapply(seq_len(n_rows), function(i) {
    dep_df <- get_dep_df(i)
    if (is.null(dep_df)) return(NULL)
    pkgs_in_dep  <- as.character(dep_df[["package"]])
    types_in_dep <- as.character(dep_df[["type"]])
    pkgs_in_dep[is_dep_type(types_in_dep)]
  }), use.names = FALSE))
  
  extra_pkgs <- setdiff(all_dep_pkgs, deps_info[["package"]])
  extra_pkgs <- extra_pkgs[!is.na(extra_pkgs)]
  extra_pkgs <- extra_pkgs[extra_pkgs != "R"]
  extra_pkgs <- extra_pkgs[!extra_pkgs %in% rownames(installed.packages())]
  
  if (length(extra_pkgs) > 0) {
    if (length(extra_pkgs) > 100) {
      cat(sprintf("Warning: %d extra deps found, capping at 100\n", length(extra_pkgs)))
      extra_pkgs <- head(extra_pkgs, 100)
    }
    cat(sprintf("Found %d additional dependency packages, fetching metadata...\n",
                length(extra_pkgs)))
    tryCatch({
      raw_extra <- pak::pkg_deps(extra_pkgs, upgrade = FALSE)
      extra_deps <- as.data.frame(raw_extra, stringsAsFactors = FALSE)
      extra_deps[["ref"]]     <- as.character(raw_extra[["ref"]])
      extra_deps[["package"]] <- as.character(raw_extra[["package"]])
      extra_deps[["version"]] <- as.character(raw_extra[["version"]])
      extra_deps[["deps"]]    <- raw_extra[["deps"]]
      bad_p <- grepl("@", extra_deps[["package"]])
      if (any(bad_p)) {
        extra_deps[["package"]][bad_p] <- sub("@.*$", "", extra_deps[["ref"]][bad_p])
      }
      bad_v <- extra_deps[["version"]] == extra_deps[["ref"]] |
               grepl("@", extra_deps[["version"]])
      if (any(bad_v)) {
        extra_deps[["version"]][bad_v] <- ifelse(
          grepl("@", extra_deps[["ref"]][bad_v]),
          sub("^[^@]+@", "", extra_deps[["ref"]][bad_v]),
          NA_character_
        )
      }
      new_rows <- extra_deps[!extra_deps[["package"]] %in% deps_info[["package"]], ]
      if (nrow(new_rows) > 0) {
        deps_info <- rbind(deps_info, new_rows)
        n_rows <- as.integer(nrow(deps_info))
      }
    }, error = function(e) warning("Could not fetch extra deps: ", e$message))
  }
  
  all_pkgs <- unique(as.character(deps_info[["package"]]))
  all_pkgs <- all_pkgs[!is.na(all_pkgs)]
  
  check_version <- function(ver, op, required_ver) {
    if (is.null(op) || is.na(op) || op == "") return(TRUE)
    if (is.null(required_ver) || is.na(required_ver) || required_ver == "") return(TRUE)
    if (is.null(ver) || is.na(ver) || ver == "" || ver == "NA") return(FALSE)
    tryCatch({
      v1 <- package_version(as.character(ver))
      v2 <- package_version(as.character(required_ver))
      switch(op,
        ">="  = v1 >= v2,
        ">"   = v1 >  v2,
        "<="  = v1 <= v2,
        "<"   = v1 <  v2,
        "=="  = v1 == v2,
        "!="  = v1 != v2,
        TRUE)
    }, error = function(e) TRUE)
  }
  
  installed_snap <- as.data.frame(
    installed.packages()[, c("Package", "Version")],
    stringsAsFactors = FALSE
  )
  
  is_already_installed <- function(pkg, required_ver) {
    idx <- match(as.character(pkg), installed_snap[["Package"]])
    if (is.na(idx)) return(FALSE)
    check_version(installed_snap[["Version"]][idx], ">=", required_ver)
  }
  
  get_deps_in_list <- function(pkg, deps_info, pkg_list) {
    row_idx <- match(pkg, deps_info[["package"]])
    if (is.na(row_idx)) return(character(0))
    dep_df <- get_dep_df(row_idx)
    if (is.null(dep_df)) return(character(0))
    dep_pkgs  <- as.character(dep_df[["package"]])
    dep_types <- as.character(dep_df[["type"]])
    dep_ops   <- as.character(dep_df[["op"]])
    dep_vers  <- as.character(dep_df[["version"]])
    keep <- is_dep_type(dep_types) & dep_pkgs %in% pkg_list
    if (!any(keep)) return(character(0))
    dep_pkgs <- dep_pkgs[keep]
    dep_ops  <- dep_ops[keep]
    dep_vers <- dep_vers[keep]
    valid <- vapply(seq_along(dep_pkgs), function(i) {
      our_idx <- match(dep_pkgs[i], deps_info[["package"]])
      if (is.na(our_idx)) return(FALSE)
      check_version(deps_info[["version"]][our_idx], dep_ops[i], dep_vers[i])
    }, FUN.VALUE = logical(1))
    dep_pkgs[valid]
  }
  
  dep_map <- setNames(
    lapply(all_pkgs, get_deps_in_list, deps_info = deps_info, pkg_list = all_pkgs),
    all_pkgs
  )
  
  remaining <- all_pkgs
  theoretical_installed <- character(0)
  batches <- list()
  
  while (length(remaining) > 0) {
    ready <- remaining[vapply(remaining, function(p) {
      deps <- dep_map[[p]]
      length(deps) == 0 || all(deps %in% theoretical_installed)
    }, FUN.VALUE = logical(1))]
    if (length(ready) == 0) {
      warning("Circular dependency or unresolvable packages: ",
              paste(remaining, collapse = ", "))
      break
    }
    batches <- c(batches, list(ready))
    theoretical_installed <- c(theoretical_installed, ready)
    remaining <- setdiff(remaining, ready)
  }
  
  cat(sprintf("\nProcessing %d batches...\n", length(batches)))
  
  for (i in seq_along(batches)) {
    current_batch_raw <- batches[[i]]
    
    to_install_mask <- vapply(current_batch_raw, function(p) {
      row_idx <- match(p, deps_info[["package"]])
      req_ver <- deps_info[["version"]][row_idx]
      !is_already_installed(p, req_ver)
    }, FUN.VALUE = logical(1))
    
    pkgs_to_process <- current_batch_raw[to_install_mask]
    
    if (length(pkgs_to_process) == 0) {
      cat(sprintf("\n--- Batch %d / %d: All packages (%d) already satisfied ---\n",
                  i, length(batches),length(current_batch_raw)))
      next
    }
    
    final_pkgs <- vapply(pkgs_to_process, make_pkg_string, FUN.VALUE = character(1))
    final_pkgs <- unname(as.vector(final_pkgs))
    
    cat(sprintf("\n--- Batch %d / %d (%d packages) ---\n",
                i, length(batches), length(final_pkgs)))
    cat("Installing:", paste(final_pkgs, collapse = ", "), "\n")
    
    for (attempt in seq_len(3)) {
      success <- tryCatch({
        pak::pkg_install(final_pkgs, dependencies = FALSE, ask = FALSE)
        TRUE
      }, error = function(e) {
        cat(sprintf("  Attempt %d/3 failed: %s\n", attempt, e$message))
        if (attempt < 3) Sys.sleep(2)
        FALSE
      })
      if (success) break
    }
  }
  
  invisible(batches)
}

# Installation
install_pkgs_batched(pkgs_1); cat("\n\n\n\n\nBLOCK 1 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_2); cat("\n\n\n\n\nBLOCK 2 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_3); cat("\n\n\n\n\nBLOCK 3 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_4); cat("\n\n\n\n\nBLOCK 4 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_5); cat("\n\n\n\n\nBLOCK 5 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_6); cat("\n\n\n\n\nBLOCK 6 R packages installed!\n\n\n\n\n")
install_pkgs_batched(pkgs_7); cat("\n\n\n\n\nBLOCK 7 R packages installed!\n\n\n\n\n")

pkg_install(c("url::https://cran.r-project.org/src/contrib/Archive/bayesbio/bayesbio_1.0.0.tar.gz",
	      "stephenturner/annotables@5bf7dc0"), dependencies = F, ask = FALSE)

pkg_install(c("url::https://cran.r-project.org/src/contrib/Archive/aPEAR/aPEAR_1.0.0.tar.gz",
              "url::https://cran.r-project.org/src/contrib/Archive/BisqueRNA/BisqueRNA_1.0.5.tar.gz",
              "url::https://cran.r-project.org/src/contrib/Archive/nVennR/nVennR_0.2.3.tar.gz"), dependencies = F, ask = FALSE)

cat("\n\n\n\n\nBLOCK 8 R packages installed!\n\n\n\n\n")

remotes::install_github("bnprks/BPCells/r", ref = "v0.3.1")

cat("\n\n\n\n\nBLOCK 9 R packages installed!\n\n\n\n\n")

unlink(list.files(path = .libPaths(), pattern = "^src$", 
                  recursive = TRUE, full.names = TRUE, include.dirs = TRUE), 
       recursive = TRUE)
pak_cleanup(force = TRUE)
EOF

    Rscript $APPTAINER_TMPDIR/install_r.R

    # --------------------------------------------------------------------------
    # 5. Perl
    # --------------------------------------------------------------------------
    apt-get install -qy --no-install-recommends \
      libconfig-inifiles-perl libconfig-ini-perl libtemplate-plugin-posix-perl \
      libscalar-list-utils-perl libwww-perl libdatetime-perl libstatistics-r-perl \
      cpanminus

    cpanm --force -q Strict::Perl LWP Cwd less Class::MOP


    # --------------------------------------------------------------------------
    # 6. Pipeline Installation & Cleanup
    # --------------------------------------------------------------------------
    git clone -q https://github.com/BioinfoIPBLN/reanalyzerGSE /reanalyzerGSE
    chmod +x /reanalyzerGSE/reanalyzerGSE.sh
    chmod +x /reanalyzerGSE/scripts/*
    chmod +x /reanalyzerGSE/external_software/miARma-seq/miARma
    rm -rf /reanalyzerGSE/test_data
    find /reanalyzerGSE -name ".git" -type d -exec rm -rf {} + 2>/dev/null || true

    # Strip Binaries (reduce size)
    find /usr/local/lib/R/site-library -name "*.so" -exec strip --strip-unneeded {} + 2>/dev/null || true
    find /usr/local/lib/python3.*/dist-packages -name "*.so" -exec strip --strip-unneeded {} + 2>/dev/null || true
    find /bin_external -type f -executable -exec strip --strip-unneeded {} + 2>/dev/null || true

    # Remove R documentation and sources
    rm -rf /usr/local/lib/R/site-library/*/help
    rm -rf /usr/local/lib/R/site-library/*/doc
    rm -rf /usr/local/lib/R/site-library/*/html

    # Remove Python cache
    find /usr/lib/python3* -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null || true
    find /usr/local/lib/python3* -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null || true
    find /usr/local/lib/python3* -name "*.pyc" -delete 2>/dev/null || true

    # Final 
    apt-get install -qy --no-install-recommends libgfortran5 libgomp1 libuv1
    apt-get autoremove -qy --purge
    apt-get clean

    # Cleanup
    rm -rf /root/.cpan 2>/dev/null || true
    rm -rf /root/.cache 2>/dev/null || true
    rm -rf /root/.npm 2>/dev/null || true


%environment
    export PATH="/bin_external/edirect:/bin_external:/bin_external/lib:/reanalyzerGSE:/reanalyzerGSE/scripts:/reanalyzerGSE/external_software/miARma-seq/:$PATH"
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
    export LD_LIBRARY_PATH="/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH"

%runscript
    exec /reanalyzerGSE/reanalyzerGSE.sh "$@"
